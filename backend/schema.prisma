generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String?   // null for google auth
  googleId         String?   @unique
  name             String
  balance          Float     @default(0)
  referralCode     String    @unique
  referredBy       String?   // userId
  role             String    @default("user") // user, admin
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  orders           Order[]
  balanceTransactions BalanceTransaction[]
  depositRequests  DepositRequest[]
}

model Product {
  id          String   @id @default(uuid())
  nameAr      String
  nameEn      String
  slug        String   @unique
  category    String   // google_play, steam, pubg_uc, etc
  price       Float
  cost        Float    // تكلفة الشراء من المزود
  executionMode String @default("api") // api, manual, both
  isActive    Boolean  @default(true)
  metadata    Json?    // صور، وصف
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
  productProviders ProductProvider[]
}

model ApiProvider {
  id               String   @id @default(uuid())
  name             String   // GamerBox, G4A
  baseUrl          String
  apiKeyEncrypted  String   // تشفير
  webhookSecret    String?
  isActive         Boolean  @default(true)
  priority         Int      @default(1) // 1 primary, 2 fallback
  createdAt        DateTime @default(now())
  productProviders ProductProvider[]
}

model ProductProvider {
  productId         String
  providerId        String
  providerProductCode String
  profitMargin      Float    @default(0)
  product           Product   @relation(fields: [productId], references: [id])
  provider          ApiProvider @relation(fields: [providerId], references: [id])
  @@id([productId, providerId])
}

model Order {
  id                String   @id @default(uuid())
  userId            String
  productId         String
  quantity          Int      @default(1)
  totalAmount       Float
  paymentMethod     String   // balance, usdt, bank_transfer, ...
  status            String   @default("pending") // pending, processing, completed, failed, refunded, pending_manual
  executionModeUsed String?
  providerId        String?
  providerResponse  Json?
  metadata          Json?    // بيانات المستخدم (UID, phone)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
  product           Product  @relation(fields: [productId], references: [id])
  provider          ApiProvider? @relation(fields: [providerId], references: [id])
}

model BalanceTransaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Float    // موجب شحن، سالب خصم
  balanceAfter Float
  type        String   // deposit, purchase, refund, commission
  referenceId String?  // orderId or depositRequestId
  reason      String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model DepositRequest {
  id              String   @id @default(uuid())
  userId          String
  amount          Float
  paymentMethod   String   // bank_transfer, crypto, vodafone_cash, mada
  receiptImageUrl String?  // للتحويل البنكي
  status          String   @default("pending") // pending, approved, rejected
  adminNotes      String?
  metadata        Json?    // حفظ productId و quantity للشراء بعد الشحن
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}